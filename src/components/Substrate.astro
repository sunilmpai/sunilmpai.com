---

<div style="
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  z-index: -2;
  pointer-events: none;
  opacity: 0.25;
" id="substrate-container"></div>

<div style="
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background-color: rgba(255, 255, 255, 0.4);
  z-index: -1;
  pointer-events: none;
"></div>

<script type="module" client:load>
  import { Runtime, Inspector } from 'https://cdn.jsdelivr.net/npm/@observablehq/runtime@5/dist/runtime.js';
  import define from "https://api.observablehq.com/@mbostock/substrate.js?v=3";

  const runtime = new Runtime();

  runtime.module(define, name => {
    if (name === "viewof context") {
      return new Inspector(document.querySelector("#substrate-container"));
    }
    return true;
  });

  runtime.redefine("n", 200); // Start with more initial points (faster immediate rendering)
  runtime.redefine("interval", 0); // Zero interval ensures immediate updates
</script>
