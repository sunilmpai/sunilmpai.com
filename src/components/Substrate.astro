---
import { onMount } from 'astro/client';
---

<div id="substrate-container" style="
    position: fixed;
    bottom: 0;
    right: 0;
    width: 400px;  /* Adjust as needed */
    height: 400px; /* Adjust as needed */
    overflow: hidden;
    z-index: -1; /* Ensures content appears on top */
    pointer-events: none;
"></div>

<script type="module">
  import { Runtime, Inspector } from '@observablehq/runtime';
  import define from '@mbostock/substrate';

  onMount(() => {
    const runtime = new Runtime();
    runtime.module(define, Inspector.into("#substrate-container"));
  });
</script>
