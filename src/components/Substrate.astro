---

<div id="substrate-container" style="
    position: fixed;
    bottom: 0;
    right: 0;
    width: 400px;
    height: 400px;
    overflow: hidden;
    z-index: -1;
    pointer-events: none;
"></div>

<script type="module" client:load>
  import { Runtime, Inspector } from 'https://cdn.jsdelivr.net/npm/@observablehq/runtime@5/dist/runtime.js';
  import define from "https://api.observablehq.com/@mbostock/substrate.js?v=3";

  const runtime = new Runtime();

  runtime.module(define, name => {
    if (name === "viewof context") {
      return new Inspector(document.querySelector("#substrate-container"));
    }
    return true; // skip all other cells
  });
</script>
